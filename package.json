  "private": true,
  "scripts": {
    "test:js": "node --test test/pkjs/**/*.test.js",
    "test:watch": "cc -std=c99 -Wall -Wextra -I./src/c ./src/c/timer.c ./test/watch/timer.test.c -o ./build/timer.test && ./build/timer.test && cc -std=c99 -Wall -Wextra -I./src/c ./src/c/vibration.c ./test/watch/vibration.test.c -o ./build/vibration.test && ./build/vibration.test"
  },
  "dependencies": {},
  "pebble": {
    "displayName": "One More Minute",
    "uuid": "A1B2C3D4-E5F6-7890-ABCD-EF1234567890",
    "projectType": "native",
    "sdkVersion": "3",
    "targetPlatforms": [
      "flint"
    ],
    "watchapp": {
      "watchface": false
    },
    "capabilities": [],
    "messageKeys": {},
    "resources": {
      "media": [
        { "type": "png", "name": "ICON_PLAY",     "file": "icon_play.png"     },
        { "type": "png", "name": "ICON_PAUSE",    "file": "icon_pause.png"    },
        { "type": "png", "name": "ICON_VIBE_ON",  "file": "icon_vibe_on.png"  },
        { "type": "png", "name": "ICON_VIBE_OFF", "file": "icon_vibe_off.png" }
      ]
    }
  }
}
